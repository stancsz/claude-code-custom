# API Keys for LiteLLM and Claude Code
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
AZURE_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=

# LiteLLM Configuration
LITELLM_MODEL=gpt-5.1-codex
LITELLM_PORT=4000
LITELLM_TELEMETRY=False
LITELLM_SOURCE=openai
# Optional override if you want a non-default config file.
# LITELLM_CONFIG_PATH=/absolute/path/to/custom/litellm/config/claude_litellm_copilot_config.yaml
# Optional Claude Code target model, e.g. deepseek-chat, qwen-max, copilot-gpt-5.2-codex.
ANTHROPIC_MODEL=
# Optional token cache location for LiteLLM's GitHub Copilot device auth flow.
GITHUB_COPILOT_TOKEN_DIR=

# Project Configuration
# Set to 'true' to enable debug mode
DEBUG=false
